    "tokenColors": [
        {
            "scope": [
                "emphasis",
                "markup.italic"
            ],
            "settings": {
                "fontStyle": "italic"
            }
        },
        {
            "scope": [
                "strong",
                "markup.bold"
            ],
            "settings": {
                "fontStyle": "bold"
            }
        },
        {
            "scope": "comment",
            "settings": {
                "foreground": "#999999"
            }
        },
        {
            "scope": "string",
            "settings": {
                "foreground": "#66ac46"
            }
        },
        {
            "scope": "constant",
            "settings": {
                "foreground": "#d1a000"
            }
        },
        {
            "scope": [
                "keyword",
                "storage"
            ],
            "settings": {
                "foreground": "#1b98f7"
            }
        }
    ]
